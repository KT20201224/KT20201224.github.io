---
// Search modal — Pagefind-backed.
// Triggered by any element with id starting with "search-trigger" or by ⌘K / Ctrl+K.
// Requires `npm run build` once to generate the /pagefind/ index.
---

<div
  id="search-modal"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Search"
  class="fixed inset-0 z-[100] hidden items-start justify-center pt-[10vh] px-4"
>
  <div data-search-backdrop class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
  <div class="relative w-full max-w-xl max-h-[80vh] flex flex-col rounded-2xl shadow-2xl bg-surface-container ghost-border overflow-hidden">
    <div class="flex items-center gap-3 p-4" style="border-bottom: 1px solid rgb(var(--color-outline-variant) / 0.3);">
      <span class="material-symbols-outlined text-on-surface-variant">search</span>
      <input
        id="search-input"
        type="text"
        placeholder="Search posts..."
        autocomplete="off"
        class="flex-1 bg-transparent border-none text-on-surface font-body text-base placeholder:text-on-surface-variant/60 focus:outline-none focus:ring-0 p-0"
      />
      <kbd class="font-label text-[10px] text-on-surface-variant bg-surface-container-high px-2 py-1 rounded">ESC</kbd>
    </div>
    <div id="search-results" class="flex-1 overflow-y-auto p-4 min-h-[200px]"></div>
    <div class="p-3 text-center text-xs font-label text-on-surface-variant" style="border-top: 1px solid rgb(var(--color-outline-variant) / 0.3);">
      Press <kbd class="bg-surface-container-high px-1.5 py-0.5 rounded text-[10px]">↵</kbd> to select ·
      <kbd class="bg-surface-container-high px-1.5 py-0.5 rounded text-[10px]">ESC</kbd> to close
    </div>
  </div>
</div>

<style>
  #search-modal[aria-hidden="false"] {
    display: flex;
  }
  #search-results:empty::before {
    content: "Type to search…";
    display: block;
    text-align: center;
    padding: 2rem;
    color: rgb(var(--color-on-surface-variant) / 0.6);
  }
  .search-result {
    display: block;
    padding: 0.875rem 1rem;
    border-radius: 0.75rem;
    text-decoration: none;
    color: rgb(var(--color-on-surface));
    transition: background 0.15s ease;
    margin-bottom: 0.25rem;
  }
  .search-result:hover,
  .search-result.selected {
    background: rgb(var(--color-primary-container) / 0.12);
  }
  .search-result-title {
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.25rem;
    color: rgb(var(--color-on-surface));
  }
  .search-result-excerpt {
    font-size: 0.825rem;
    color: rgb(var(--color-on-surface-variant));
    line-height: 1.4;
  }
  .search-result-excerpt :global(mark) {
    background: rgb(var(--color-primary-container) / 0.25);
    color: rgb(var(--color-primary-container));
    padding: 0 0.125rem;
    border-radius: 2px;
  }
</style>

<script is:inline>
  (function () {
    let pagefind = null;

    async function wire() {
      const modal = document.getElementById('search-modal');
      if (!modal || modal.dataset.wired) return;
      modal.dataset.wired = '1';

      const backdrop = modal.querySelector('[data-search-backdrop]');
      const input = document.getElementById('search-input');
      const results = document.getElementById('search-results');

      function openModal() {
        modal.setAttribute('aria-hidden', 'false');
        setTimeout(() => input.focus(), 0);
        document.body.style.overflow = 'hidden';
      }
      function closeModal() {
        modal.setAttribute('aria-hidden', 'true');
        input.value = '';
        results.innerHTML = '';
        document.body.style.overflow = '';
      }

      document.querySelectorAll('[id^="search-trigger"]').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          openModal();
        });
      });

      backdrop && backdrop.addEventListener('click', closeModal);

      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && (e.key === 'k' || e.key === 'K')) {
          e.preventDefault();
          openModal();
        }
        if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') {
          closeModal();
        }
      });

      let searchId = 0;
      input.addEventListener('input', async () => {
        const query = input.value.trim();
        const myId = ++searchId;

        if (!query) {
          results.innerHTML = '';
          return;
        }

        if (!pagefind) {
          try {
            pagefind = await import('/pagefind/pagefind.js');
            await pagefind.init();
          } catch (err) {
            if (myId !== searchId) return;
            results.innerHTML =
              '<div style="text-align:center;padding:2rem;color:rgb(var(--color-on-surface-variant) / 0.7);">Search index not available.<br><small>Run <code style="background:rgb(var(--color-surface-container-high));padding:2px 6px;border-radius:4px;">npm run build</code> to generate.</small></div>';
            return;
          }
        }

        const search = await pagefind.search(query);
        if (myId !== searchId) return;
        const data = await Promise.all(search.results.slice(0, 10).map((r) => r.data()));
        if (myId !== searchId) return;

        if (data.length === 0) {
          results.innerHTML = '<div style="text-align:center;padding:2rem;color:rgb(var(--color-on-surface-variant) / 0.7);">No results for "' + query.replace(/</g, '&lt;') + '"</div>';
          return;
        }

        results.innerHTML = data
          .map(
            (r) =>
              '<a href="' + r.url + '" class="search-result">' +
              '<div class="search-result-title">' + (r.meta && r.meta.title ? r.meta.title : 'Untitled') + '</div>' +
              '<div class="search-result-excerpt">' + r.excerpt + '</div>' +
              '</a>',
          )
          .join('');
      });
    }

    wire();
    document.addEventListener('astro:after-swap', wire);
  })();
</script>
