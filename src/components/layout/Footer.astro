---
const year = new Date().getFullYear();
---

<footer class="bg-surface-container-lowest w-full py-12 mt-20 opacity-80 hover:opacity-100 transition-opacity">
  <div class="max-w-7xl mx-auto px-8 flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="font-label text-[11px] tracking-widest uppercase text-on-surface-variant text-center md:text-left">
      © {year} Kyoungtae Kim. All rights reserved.
    </div>

    <div class="font-label text-[10px] tracking-widest uppercase text-outline text-center order-last md:order-none">
      Built with
      <a
        href="https://astro.build"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-primary-container transition-colors no-underline"
      >Astro</a>
      · Deployed on
      <a
        href="https://pages.github.com"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-primary-container transition-colors no-underline"
      >GitHub Pages</a>
    </div>

    <nav class="flex items-center gap-6 font-label text-[11px] tracking-widest uppercase">
      <a
        href="/rss.xml"
        target="_blank"
        class="text-on-surface-variant hover:text-primary-container transition-colors no-underline"
      >
        RSS
      </a>
    </nav>
  </div>
</footer>
