---
import { SITE_TITLE, SOCIAL_LINKS } from "../../lib/constants";
const year = new Date().getFullYear();
---

<footer class="bg-surface-container-lowest w-full py-12 mt-20 pb-24 md:pb-12 opacity-80 hover:opacity-100 transition-opacity">
  <div class="max-w-7xl mx-auto px-8 flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="font-headline text-lg font-bold text-on-surface">
      {SITE_TITLE}
    </div>

    <div class="font-label text-[11px] tracking-widest uppercase text-on-surface-variant text-center order-last md:order-none">
      © {year} Kyoungtae Kim. All rights reserved.
    </div>

    <nav class="flex items-center gap-6 font-label text-[11px] tracking-widest uppercase">
      <a
        href={SOCIAL_LINKS.github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-on-surface-variant hover:text-primary-container transition-colors no-underline"
      >
        GitHub
      </a>
      <a
        href={`mailto:${SOCIAL_LINKS.email}`}
        class="text-on-surface-variant hover:text-primary-container transition-colors no-underline"
      >
        Email
      </a>
      <a
        href="/rss.xml"
        target="_blank"
        class="text-on-surface-variant hover:text-primary-container transition-colors no-underline"
      >
        RSS
      </a>
    </nav>
  </div>
</footer>
