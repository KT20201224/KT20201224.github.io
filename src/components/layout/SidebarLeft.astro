---
import { getCollection } from "astro:content";
import { CATEGORIES, SOCIAL_LINKS } from "../../lib/constants";
import { getPublishedPosts, getTagsWithCount } from "../../lib/utils";
import ThemeToggle from "../ui/ThemeToggle.astro";

const pathname = Astro.url.pathname;

const allPosts = await getCollection("blog");
const publishedPosts = getPublishedPosts(allPosts);
const totalPosts = publishedPosts.length;
const totalTags = getTagsWithCount(publishedPosts).length;

const now = Date.now();
const thirtyDaysAgo = now - 30 * 24 * 60 * 60 * 1000;
const recentCount = publishedPosts.filter(
  (p) => p.data.pubDate.valueOf() >= thirtyDaysAgo,
).length;

const categoryIcons: Record<string, string> = {
  "ai-ml": "psychology",
  dev: "code",
  news: "newspaper",
  til: "school",
  etc: "more_horiz",
};
---

<aside class="sticky top-24 self-start mx-4 mb-4 h-[calc(100vh-7rem)] w-64 hidden lg:flex flex-col flex-shrink-0 rounded-2xl shadow-xl bg-surface-container-low z-40 overflow-y-auto ghost-border">
  <!-- Compact Profile -->
  <div class="px-6 pt-6 pb-4 flex items-center gap-3">
    <div class="w-10 h-10 rounded-full overflow-hidden bg-surface-container flex-shrink-0">
      <img
        src="/images/etc/jerry_profile.jpg"
        alt="Jerry"
        class="w-full h-full object-cover"
      />
    </div>
    <div class="min-w-0 flex-1">
      <p class="text-sm font-bold font-headline text-on-surface leading-tight truncate">Kyoungtae Kim</p>
      <p class="text-[10px] font-mono tracking-widest text-outline uppercase opacity-60 mt-0.5">Jerry's Archive</p>
    </div>
    <ThemeToggle />
  </div>

  <!-- System Metrics -->
  <div class="mx-4 mb-4 px-4 py-5 rounded-xl bg-surface-container-high/60">
    <h3 class="font-headline text-[10px] uppercase tracking-widest text-on-surface-variant mb-3 font-bold flex items-center gap-1.5">
      <span class="material-symbols-outlined text-primary text-sm">bar_chart</span>
      System Metrics
    </h3>
    <div class="flex flex-col gap-2.5">
      <div class="flex justify-between items-baseline">
        <span class="font-body text-xs text-on-surface-variant">Total Posts</span>
        <span class="font-headline text-base font-bold text-primary">{totalPosts}</span>
      </div>
      <div class="flex justify-between items-baseline">
        <span class="font-body text-xs text-on-surface-variant">Total Tags</span>
        <span class="font-headline text-base font-bold text-primary">{totalTags}</span>
      </div>
      <div class="flex justify-between items-baseline">
        <span class="font-body text-xs text-on-surface-variant">Recent (30d)</span>
        <span class="font-headline text-base font-bold text-on-surface">{recentCount}</span>
      </div>
    </div>
  </div>

  <!-- Category Nav (floating cards) -->
  <nav class="px-4 space-y-2.5">
    {(() => {
      const isAllPostsActive = pathname === '/blog';
      return (
        <a
          href="/blog"
          class={`flex items-center gap-3 px-3 py-4 rounded-xl shadow-md transition-all no-underline ${
            isAllPostsActive
              ? 'bg-primary-container/15 text-primary-container ring-1 ring-primary-container/30'
              : 'bg-surface-container-high/60 text-on-surface-variant hover:bg-surface-container-high hover:text-on-surface'
          }`}
        >
          <span class={`w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 ${
            isAllPostsActive
              ? 'bg-primary-container/30 text-primary-container'
              : 'bg-surface-container-highest text-outline'
          }`}>
            <span class="material-symbols-outlined text-lg">article</span>
          </span>
          <span class="text-xs font-mono font-label uppercase tracking-wider">ALL</span>
        </a>
      );
    })()}

    {CATEGORIES.map((cat) => {
      const href = `/categories/${cat.slug}`;
      const isActive = pathname.startsWith(href);
      return (
        <a
          href={href}
          class={`flex items-center gap-3 px-3 py-4 rounded-xl shadow-md transition-all no-underline ${
            isActive
              ? 'bg-primary-container/15 text-primary-container ring-1 ring-primary-container/30'
              : 'bg-surface-container-high/60 text-on-surface-variant hover:bg-surface-container-high hover:text-on-surface'
          }`}
        >
          <span class={`w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 ${
            isActive
              ? 'bg-primary-container/30 text-primary-container'
              : 'bg-surface-container-highest text-outline'
          }`}>
            <span class="material-symbols-outlined text-lg">{categoryIcons[cat.slug] || 'folder'}</span>
          </span>
          <span class="text-xs font-mono font-label uppercase tracking-wider">{cat.label}</span>
        </a>
      );
    })}
  </nav>

  <!-- Social links at bottom -->
  <div class="p-6 mt-auto">
    <div class="flex gap-3 justify-center">
      <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer"
        class="text-slate-600 hover:text-primary-container transition-colors text-[10px] font-mono uppercase tracking-widest">
        GitHub
      </a>
      <span class="text-slate-700">·</span>
      <a href={`mailto:${SOCIAL_LINKS.email}`}
        class="text-slate-600 hover:text-primary-container transition-colors text-[10px] font-mono uppercase tracking-widest">
        Email
      </a>
    </div>
  </div>
</aside>
