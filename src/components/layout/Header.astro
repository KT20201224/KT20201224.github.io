---
import { SITE_TITLE, NAV_LINKS } from "../../lib/constants";
const pathname = Astro.url.pathname;
const navIcons: Record<string, string> = {
  '/': 'home',
  '/blog': 'article',
  '/news': 'newspaper',
  '/projects': 'grid_view',
  '/til': 'school',
  '/about': 'person',
};
---

<header class="fixed top-0 w-full z-50 bg-surface/60 backdrop-blur-xl shadow-[0px_24px_48px_rgba(0,218,243,0.04)]">
  <div class="flex justify-between items-center w-full px-6 py-4 max-w-7xl mx-auto">
    <!-- Logo -->
    <a href="/" class="text-xl font-bold tracking-tighter text-primary-container font-headline no-underline hover:opacity-80 transition-opacity">
      {SITE_TITLE}
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8 font-label text-xs uppercase tracking-widest">
      {NAV_LINKS.map((link) => {
        const isActive = pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href + '/'));
        return (
          <a
            href={link.href}
            class={isActive
              ? "text-primary-container border-b-2 border-primary-container pb-1"
              : "text-slate-400 hover:text-slate-100 transition-colors"}
          >
            {link.label}
          </a>
        );
      })}
    </nav>

    <!-- Right Actions -->
    <div class="flex items-center gap-3">
      <!-- Search box -->
      <div class="relative hidden sm:block">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-base">search</span>
        <input
          id="search-input"
          type="text"
          placeholder="Search..."
          class="bg-surface-container-lowest border border-outline-variant/40 rounded-lg pl-10 pr-4 py-2 text-sm font-label text-on-surface placeholder-outline focus:ring-1 focus:ring-primary-container/40 focus:outline-none w-52 transition-all"
        />
      </div>
      <!-- Mobile search icon -->
      <button class="sm:hidden text-slate-400 hover:text-primary-container transition-colors" aria-label="검색">
        <span class="material-symbols-outlined">search</span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile bottom nav -->
<nav class="md:hidden fixed bottom-0 w-full bg-surface-container-low/90 backdrop-blur-lg border-t border-outline-variant/20 py-3 px-6 z-50 flex justify-around">
  {NAV_LINKS.map((link) => {
    const isActive = pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href + '/'));
    return (
      <a
        href={link.href}
        class={`flex flex-col items-center gap-1 no-underline ${isActive ? 'text-primary-container' : 'text-slate-500'}`}
      >
        <span class="material-symbols-outlined text-[22px]">{navIcons[link.href] || 'circle'}</span>
        <span class="text-[9px] font-label uppercase">{link.label}</span>
      </a>
    );
  })}
</nav>
