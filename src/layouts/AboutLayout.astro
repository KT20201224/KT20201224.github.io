---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  heroImage?: string;
}

const { title, description, heroImage } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="max-w-3xl mx-auto">
    {heroImage && (
      <div class="mb-12 rounded-xl overflow-hidden" style="aspect-ratio: 2/1;">
        <img src={heroImage} alt="" class="w-full h-full object-cover" style="object-position: center 70%;" />
      </div>
    )}
    <div class="prose max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
