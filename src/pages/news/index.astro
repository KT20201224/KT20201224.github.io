---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/common/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../lib/constants';

const news = (await getCollection('news')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title={`News | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
  <header class="mb-12">
    <span class="font-label text-xs uppercase tracking-[0.3em] text-primary-container mb-4 block">Updates</span>
    <h1 class="text-5xl font-extrabold font-headline tracking-tighter text-on-surface">Tech News</h1>
    <p class="text-outline font-body italic mt-2">최신 기술 동향과 업데이트</p>
  </header>

  <section class="space-y-6">
    {news.map((post) => (
      <a
        href={`/news/${post.id}/`}
        class="block p-6 rounded-xl bg-surface-container border border-outline-variant/20 hover:border-primary-container/20 hover:bg-surface-container-high/50 transition-all group no-underline"
      >
        <div class="flex items-start gap-6">
          <div class="flex-shrink-0 text-center">
            <span class="block text-[10px] font-label uppercase tracking-widest text-primary-container bg-primary-container/10 px-2 py-1 rounded">
              <FormattedDate date={post.data.pubDate} />
            </span>
          </div>
          <div class="flex-1 min-w-0">
            <h2 class="text-xl font-bold font-headline text-on-surface group-hover:text-primary-container transition-colors mb-2">
              {post.data.title}
            </h2>
            {post.data.description && (
              <p class="text-outline font-body leading-relaxed line-clamp-2">
                {post.data.description}
              </p>
            )}
          </div>
          <span class="material-symbols-outlined text-outline-variant group-hover:text-primary-container transition-colors flex-shrink-0">
            arrow_forward
          </span>
        </div>
      </a>
    ))}

    {news.length === 0 && (
      <div class="text-center py-20">
        <span class="material-symbols-outlined text-6xl text-outline-variant mb-4 block">newspaper</span>
        <p class="text-outline font-label uppercase tracking-widest text-sm">아직 뉴스가 없습니다</p>
      </div>
    )}
  </section>
</BaseLayout>
