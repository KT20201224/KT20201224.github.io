---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/common/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../lib/constants';
import { getFirstImage, getImageUrl } from '../../lib/utils';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
  <!-- Page Header -->
  <header class="mb-16">
    <span class="font-label text-xs uppercase tracking-[0.3em] text-primary-container mb-4 block">Index of Knowledge</span>
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <h1 class="text-5xl md:text-6xl font-extrabold font-headline tracking-tighter text-on-surface leading-tight">
          Latest <br/>
          <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(135deg, #c3f5ff 0%, #00e5ff 100%)">
            Articles.
          </span>
        </h1>
      </div>
      <div class="flex gap-4">
        <div class="flex items-center gap-2 px-4 py-2 bg-surface-container rounded-lg font-label text-xs text-outline">
          <span class="material-symbols-outlined text-sm">article</span>
          총 {posts.length}개의 글
        </div>
      </div>
    </div>
  </header>

  <!-- Post Listing (Stitch style) -->
  <section class="space-y-12">
    {posts.map((post) => {
      const image = post.data.heroImage || getFirstImage(post.body);
      const imageUrl = getImageUrl(image);
      return (
        <article class="group relative grid md:grid-cols-12 gap-8 items-start py-8 transition-all hover:bg-surface-container-low/50 rounded-2xl px-4 -mx-4 cursor-pointer">
          <a href={`/blog/${post.id}/`} class="absolute inset-0 z-0 rounded-2xl" aria-label={post.data.title}></a>
          {/* Thumbnail */}
          <div class="md:col-span-4 aspect-video rounded-xl overflow-hidden bg-surface-container-high">
            {imageUrl ? (
              <img
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                src={imageUrl}
                alt={post.data.title}
                loading="lazy"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center">
                <span class="material-symbols-outlined text-4xl text-outline-variant">article</span>
              </div>
            )}
          </div>

          {/* Content */}
          <div class="md:col-span-8 flex flex-col justify-between h-full">
            <div>
              <div class="flex items-center gap-4 mb-4">
                <span class="font-label text-[10px] uppercase tracking-widest text-outline">
                  <FormattedDate date={post.data.pubDate} />
                </span>
                {post.data.category && (
                  <>
                    <span class="w-1 h-1 rounded-full bg-outline-variant"></span>
                    <span class="font-label text-[10px] uppercase tracking-widest text-outline">
                      {post.data.category}
                    </span>
                  </>
                )}
              </div>
              <h2 class="text-2xl font-bold font-headline mb-3 text-on-surface group-hover:text-primary-container transition-colors">
                {post.data.title}
              </h2>
              {post.data.description && (
                <p class="text-outline font-body leading-relaxed mb-6 text-lg line-clamp-2">
                  {post.data.description}
                </p>
              )}
            </div>
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {post.data.tags.slice(0, 3).map((tag: string) => (
                  <a
                    href={`/tags/${tag}`}
                    class="relative z-10 px-3 py-1 rounded-full bg-primary-container/10 text-primary-container font-label text-[10px] uppercase tracking-wider border border-primary-container/20 hover:bg-primary-container/20 transition-colors no-underline"
                  >
                    {tag}
                  </a>
                ))}
              </div>
            )}
          </div>
        </article>
      );
    })}
  </section>

  {posts.length === 0 && (
    <div class="text-center py-20">
      <span class="material-symbols-outlined text-6xl text-outline-variant mb-4 block">article</span>
      <p class="text-outline font-label uppercase tracking-widest text-sm">아직 게시글이 없습니다</p>
    </div>
  )}
</BaseLayout>
