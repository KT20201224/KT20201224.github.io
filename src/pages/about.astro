---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SOCIAL_LINKS } from "../lib/constants";

// === Solved.ac (백준) ===
const handle = "olly123";
let data: { tier?: number; solvedCount?: number; rating?: number } | null = null;
try {
  const res = await fetch(`https://solved.ac/api/v3/user/show?handle=${handle}`);
  if (res.ok) {
    data = await res.json();
  }
} catch (e) {
  // API unavailable at build time, show fallback
}

// === Kaggle (수동) ===
const kaggleData = {
  tier: "Expert",
  username: "kyoungteakim",
};

const tierNames = [
  "Unrated",
  "Bronze V", "Bronze IV", "Bronze III", "Bronze II", "Bronze I",
  "Silver V", "Silver IV", "Silver III", "Silver II", "Silver I",
  "Gold V", "Gold IV", "Gold III", "Gold II", "Gold I",
  "Platinum V", "Platinum IV", "Platinum III", "Platinum II", "Platinum I",
  "Diamond V", "Diamond IV", "Diamond III", "Diamond II", "Diamond I",
  "Ruby V", "Ruby IV", "Ruby III", "Ruby II", "Ruby I",
];

// Professional Trajectory
const experiences = [
  {
    company: "한국전자기술연구원",
    role: "연구원",
    period: "2021.07 - 2022.08",
    details: [
      "유니티를 활용한 디지털트윈 환경 구축",
      "데이터 시각화",
    ],
    active: true,
  },
];

// Activities
const activities = [
  {
    title: "컴퓨터응용소프트웨어 제 36대 학생회",
    role: "학생회장",
    period: "2021.11 - 2022.10",
    details: ["학과 학생회 운영"],
  },
  {
    title: "웹개발 동아리 \"원더독\"",
    role: "동아리원",
    period: "2022.03 - 2022.07",
    details: ["Django 웹 개발"],
  },
  {
    title: "자기주도적설계프로그램",
    role: "팀장",
    period: "2018.03 - 2018.07",
    details: ["\"스마트 미러\" 개발", "장려상 수상"],
  },
];

// Certifications
const certifications = [
  { name: "정보처리기사", issuer: "한국산업인력공단", date: "2022.11" },
  { name: "SQLD", issuer: "한국데이터산업진흥원", date: "2024.06" },
];

// Tech stack
const techStack = {
  languages: [
    { name: "JavaScript", icon: "https://cdn.simpleicons.org/javascript/F7DF1E" },
    { name: "TypeScript", icon: "https://cdn.simpleicons.org/typescript/3178C6" },
    { name: "Python", icon: "https://cdn.simpleicons.org/python/3776AB" },
    { name: "Java", icon: "https://cdn.simpleicons.org/openjdk/000000" },
    { name: "C", icon: "https://cdn.simpleicons.org/c/A8B9CC" },
    { name: "R", icon: "https://cdn.simpleicons.org/r/276DC3" },
  ],
  frameworks: [
    { name: "React", icon: "https://cdn.simpleicons.org/react/61DAFB" },
    { name: "Node.js", icon: "https://cdn.simpleicons.org/nodedotjs/339933" },
    { name: "Spring", icon: "https://cdn.simpleicons.org/spring/6DB33F" },
  ],
  tools: [
    { name: "Git", icon: "https://cdn.simpleicons.org/git/F05032" },
    { name: "VS Code", icon: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/vscode/vscode-original.svg" },
    { name: "Docker", icon: "https://cdn.simpleicons.org/docker/2496ED" },
  ],
};
---

<BaseLayout title="About Me" description="KT 소개">
  <div class="max-w-4xl mx-auto space-y-12">

    <!-- Profile Card (Glassmorphism) -->
    <section
      class="bg-surface-variant/60 backdrop-blur-xl rounded-xl p-8 relative overflow-hidden group"
      style="border: 1px solid rgba(84, 68, 51, 0.15);"
    >
      <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
      <div class="relative z-10 flex flex-col md:flex-row items-center md:items-start gap-8">
        <div class="relative shrink-0">
          <div class="absolute -inset-1 bg-gradient-to-r from-primary to-primary-container rounded-full blur opacity-20"></div>
          <img
            src="/images/etc/profile.jpg"
            alt="Kyoungtae Kim"
            class="relative w-40 h-40 rounded-full object-cover"
            style="border: 1px solid rgba(84, 68, 51, 0.3);"
          />
        </div>
        <div class="text-center md:text-left flex-1">
          <h1 class="font-headline text-4xl md:text-5xl font-bold tracking-tight mb-2 text-on-surface">
            김경태
          </h1>
          <p class="font-body text-xl text-on-surface-variant mb-6">
            Software Engineer · AI Learner
          </p>
          <p class="font-body text-base leading-relaxed mb-4 max-w-2xl text-on-surface-variant">
            이 블로그는 제가 공부한 내용을 정리하고 공유하기 위한 공간입니다.
            프론트엔드, 백엔드, 클라우드, AI 영역을 불문하고 IT 기술에 관심이 많습니다.
          </p>
          <p class="font-body text-base leading-relaxed mb-8 max-w-2xl text-on-surface-variant">
            현재는 카카오테크 부트캠프에서 AI를 집중적으로 공부하고 있으며,
            새로운 기술을 배우고 문제를 해결하는 과정을 즐깁니다.
          </p>
          <div class="flex flex-wrap justify-center md:justify-start gap-4">
            <a
              href={`mailto:${SOCIAL_LINKS.email}`}
              class="flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors text-sm font-label no-underline"
            >
              <span class="material-symbols-outlined text-[20px]">mail</span>
              {SOCIAL_LINKS.email}
            </a>
            <a
              href={SOCIAL_LINKS.github}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors text-sm font-label no-underline"
            >
              <span class="material-symbols-outlined text-[20px]">link</span>
              GitHub
            </a>
            <a
              href={SOCIAL_LINKS.tistory}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors text-sm font-label no-underline"
            >
              <span class="material-symbols-outlined text-[20px]">public</span>
              Tistory
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Technical Skills -->
    <section class="bg-surface-container-low rounded-xl p-8 relative" style="border: 1px solid rgba(84, 68, 51, 0.15);">
      <h2 class="font-headline text-2xl font-bold mb-8 flex items-center gap-3 text-on-surface">
        <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">code</span>
        Technical Skills
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <h3 class="font-body text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-4">Languages</h3>
          <div class="flex flex-wrap gap-2">
            {techStack.languages.map((item) => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-surface-container rounded-sm text-sm font-label text-on-surface" style="border: 1px solid rgba(84, 68, 51, 0.15);">
                <img src={item.icon} alt="" class="w-4 h-4 object-contain" />
                {item.name}
              </span>
            ))}
          </div>
        </div>
        <div>
          <h3 class="font-body text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-4">Frameworks</h3>
          <div class="flex flex-wrap gap-2">
            {techStack.frameworks.map((item) => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-secondary-container/20 text-secondary rounded-sm text-sm font-label" style="border: 1px solid rgba(212, 187, 255, 0.2);">
                <img src={item.icon} alt="" class="w-4 h-4 object-contain" />
                {item.name}
              </span>
            ))}
          </div>
        </div>
        <div>
          <h3 class="font-body text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-4">Tools</h3>
          <div class="flex flex-wrap gap-2">
            {techStack.tools.map((item) => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-tertiary-container/20 text-tertiary rounded-sm text-sm font-label" style="border: 1px solid rgba(123, 225, 214, 0.2);">
                <img src={item.icon} alt="" class="w-4 h-4 object-contain" />
                {item.name}
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Professional Trajectory -->
    <section class="bg-surface-container-lowest rounded-xl p-8 relative">
      <h2 class="font-headline text-2xl font-bold mb-8 flex items-center gap-3 text-on-surface">
        <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">timeline</span>
        Professional Trajectory
      </h2>
      <div class="space-y-8 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-outline-variant/20">
        {experiences.map((exp, i) => {
          const isOdd = i % 2 === 0;
          return (
            <div class={`relative flex items-start justify-between md:justify-normal ${isOdd ? '' : 'md:flex-row-reverse'} group`}>
              <div class={`flex items-center justify-center w-10 h-10 rounded-full shrink-0 md:order-1 ${isOdd ? 'md:-translate-x-1/2' : 'md:translate-x-1/2'} z-10 bg-surface-container-low ${exp.active ? 'shadow-[0_0_15px_rgba(255,159,0,0.2)]' : ''}`} style={`border: 1px solid ${exp.active ? '#ffc687' : 'rgba(84, 68, 51, 0.3)'};`}>
                <span class={`rounded-full ${exp.active ? 'w-3 h-3 bg-primary blur-[1px]' : 'w-2 h-2 bg-outline-variant/50'}`}></span>
              </div>
              <div class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] bg-surface-container p-6 rounded-xl" style="border: 1px solid rgba(84, 68, 51, 0.15);">
                <div class="flex flex-col md:flex-row md:items-center justify-between mb-2">
                  <h3 class="font-headline font-bold text-lg text-on-surface">{exp.company}</h3>
                  <span class={`font-label text-xs px-2 py-1 rounded-sm mt-2 md:mt-0 ${exp.active ? 'bg-primary-container/10 text-primary' : 'bg-surface-container-high text-on-surface-variant'}`}>
                    {exp.period}
                  </span>
                </div>
                <h4 class="font-body text-sm text-on-surface-variant mb-4">{exp.role}</h4>
                <ul class="space-y-1.5 text-sm text-on-surface-variant leading-relaxed list-disc list-inside">
                  {exp.details.map((d) => (<li>{d}</li>))}
                </ul>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Activities -->
    <section class="bg-surface-container-low rounded-xl p-8" style="border: 1px solid rgba(84, 68, 51, 0.15);">
      <h2 class="font-headline text-2xl font-bold mb-8 flex items-center gap-3 text-on-surface">
        <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">groups</span>
        Activities
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {activities.map((a) => (
          <div class="bg-surface-container p-6 rounded-xl hover:bg-surface-bright/20 transition-colors" style="border: 1px solid rgba(84, 68, 51, 0.15);">
            <div class="flex items-start justify-between mb-2 gap-3">
              <h3 class="font-headline font-bold text-base text-on-surface leading-snug">{a.title}</h3>
              <span class="font-label text-[10px] whitespace-nowrap text-on-surface-variant bg-surface-container-high px-2 py-1 rounded-sm">{a.period}</span>
            </div>
            <p class="font-body text-sm text-primary mb-3">{a.role}</p>
            <ul class="space-y-1 text-sm text-on-surface-variant list-disc list-inside">
              {a.details.map((d) => (<li>{d}</li>))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Certifications -->
    <section class="bg-surface-container-low rounded-xl p-8" style="border: 1px solid rgba(84, 68, 51, 0.15);">
      <h2 class="font-headline text-2xl font-bold mb-8 flex items-center gap-3 text-on-surface">
        <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">workspace_premium</span>
        Certifications
      </h2>
      <div class="flex flex-col gap-4">
        {certifications.map((c) => (
          <div class="flex items-center justify-between p-5 bg-surface-container rounded-xl transition-colors hover:bg-surface-bright/20" style="border: 1px solid rgba(84, 68, 51, 0.15);">
            <div>
              <h3 class="font-headline font-bold text-base text-on-surface mb-1">{c.name}</h3>
              <p class="font-body text-sm text-on-surface-variant">{c.issuer}</p>
            </div>
            <span class="font-headline font-bold text-primary text-sm">{c.date}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Stats Grid: Algorithm + Kaggle -->
    <section class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-surface-container-low rounded-xl p-8" style="border: 1px solid rgba(84, 68, 51, 0.15);">
        <h2 class="font-headline text-xl font-bold mb-6 flex items-center gap-3 text-on-surface">
          <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">integration_instructions</span>
          Algorithm (백준)
        </h2>
        <div class="grid grid-cols-3 gap-3">
          <div class="bg-surface-container p-4 rounded-lg" style="border: 1px solid rgba(84, 68, 51, 0.15);">
            <div class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant mb-1">Tier</div>
            <div class="font-headline text-lg font-bold text-primary">{data ? tierNames[data.tier ?? 0] : '-'}</div>
          </div>
          <div class="bg-surface-container p-4 rounded-lg" style="border: 1px solid rgba(84, 68, 51, 0.15);">
            <div class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant mb-1">Solved</div>
            <div class="font-headline text-lg font-bold text-primary">{data?.solvedCount ?? '-'}</div>
          </div>
          <div class="bg-surface-container p-4 rounded-lg" style="border: 1px solid rgba(84, 68, 51, 0.15);">
            <div class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant mb-1">Rating</div>
            <div class="font-headline text-lg font-bold text-primary">{data?.rating ?? '-'}</div>
          </div>
        </div>
      </div>

      <div class="bg-surface-container-low rounded-xl p-8" style="border: 1px solid rgba(84, 68, 51, 0.15);">
        <h2 class="font-headline text-xl font-bold mb-6 flex items-center gap-3 text-on-surface">
          <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">workspace_premium</span>
          Kaggle
        </h2>
        <div class="bg-surface-container p-4 rounded-lg" style="border: 1px solid rgba(84, 68, 51, 0.15);">
          <div class="font-label text-[10px] uppercase tracking-widest text-on-surface-variant mb-1">Tier</div>
          <div class="font-headline text-lg font-bold text-primary">{kaggleData.tier}</div>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>
