---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../lib/constants';
import { getTagsWithCount, getPublishedPosts } from '../../lib/utils';

const allPosts = await getCollection('blog');
const publishedPosts = getPublishedPosts(allPosts);
const tags = getTagsWithCount(publishedPosts);
---

<BaseLayout title={`Tags | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
  <header class="mb-12">
    <span class="font-label text-xs uppercase tracking-[0.3em] text-primary-container mb-4 block">Categories</span>
    <h1 class="text-5xl font-extrabold font-headline tracking-tighter text-on-surface">Tags</h1>
    <p class="text-outline font-label text-sm mt-2">{tags.length}개의 태그</p>
  </header>

  {tags.length > 0 ? (
    <div class="flex flex-wrap gap-3">
      {tags.map((tag) => (
        <a
          href={`/tags/${tag.name}/`}
          class="flex items-center gap-2 px-4 py-2.5 rounded-lg bg-surface-container border border-outline-variant/20 hover:border-primary-container/30 hover:bg-surface-container-high transition-all no-underline group"
        >
          <span class="text-sm font-label font-medium text-on-surface group-hover:text-primary-container transition-colors">
            #{tag.name}
          </span>
          <span class="text-xs font-bold font-label text-on-primary bg-primary-container px-1.5 py-0.5 rounded-full min-w-[1.5rem] text-center">
            {tag.count}
          </span>
        </a>
      ))}
    </div>
  ) : (
    <div class="text-center py-20">
      <span class="material-symbols-outlined text-6xl text-outline-variant mb-4 block">label</span>
      <p class="text-outline font-label uppercase tracking-widest text-sm">아직 태그가 없습니다</p>
    </div>
  )}
</BaseLayout>
